# LLM Provider Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=central-bank-swaps

# Browser Profile (optional)
# Path to a Chromium user-data directory for persistent cookies across runs.
# Enables bot-manager session cookies (Radware/Cloudflare) to survive between
# pipeline runs so that sites like BanRep skip the JS challenge after the first visit.
# Example: CBS_BROWSER_PROFILE=/home/user/.cbs/browser_profile
CBS_BROWSER_PROFILE=
